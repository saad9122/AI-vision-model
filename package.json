{
  "name": "ai-description-service",
  "version": "1.0.0",
  "description": "AI microservice that generates descriptions and issue reports for room items from images using Ollama (qwen2.5vl)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "nodemon dist/index.js",
    "start:worker": "node dist/queue/worker.js",
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/queue/worker.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.620.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.18.0",
    "axios": "^1.7.4",
    "bullmq": "^5.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "5.10.1",
    "nodemon": "^3.1.14",
    "openai": "^6.42.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "sharp": "^0.33.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.15",
    "prisma": "^5.18.0",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4"
  }
}
