generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AgentCapability {
  DESCRIPTION_GENERATOR
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model AgentJob {
  id         String          @id @default(uuid())
  capability AgentCapability
  payload    Json
  result     Json?
  status     JobStatus       @default(PENDING)
  error      String?

  tenantId   String?         @map("tenant_id")
  schemaName String?         @map("schema_name")
  userId     String?         @map("user_id")
  userName   String?         @map("user_name")
  imageCount Int?            @map("image_count")
  images     Json?

  reviewSubmittedAt DateTime? @map("review_submitted_at")
  reviewNote        String?   @map("review_note")
  reviewLiked       Boolean?  @map("review_liked")

  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  @@index([capability, status])
  @@index([createdAt], map: "AgentJob_created_at_idx")
  @@index([tenantId])
  @@index([userId])
}
