generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// A single request to describe a room item, possibly using multiple images.
// "descriptionTypes" controls which AI outputs are generated:
//   GENERAL -> a plain description of the item (type, material, color, condition)
//   ISSUES  -> a defect/issue report (cracks, peeling paint, broken parts, etc.)
model DescriptionJob {
  id               String    @id @default(uuid())

  // Context supplied by the backend - known in advance
  roomName         String
  itemName         String

  // S3 object keys for the uploaded images related to this room item
  imageKeys        String[]

  // Which description(s) to generate for this job
  descriptionTypes String[]

  status           JobStatus @default(PENDING)

  // { "general": "...", "issues": "..." }
  result           Json?

  error            String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}
